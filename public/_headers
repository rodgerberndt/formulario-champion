# Long-term cache for hashed Vite assets (filenames contain content hash)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images, fonts, audio in /public — 7 days, allow CDN revalidate
/*.webp
  Cache-Control: public, max-age=604800, must-revalidate
/*.png
  Cache-Control: public, max-age=604800, must-revalidate
/*.jpg
  Cache-Control: public, max-age=604800, must-revalidate
/*.jpeg
  Cache-Control: public, max-age=604800, must-revalidate
/*.svg
  Cache-Control: public, max-age=604800, must-revalidate
/*.ico
  Cache-Control: public, max-age=604800, must-revalidate
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.ttf
  Cache-Control: public, max-age=31536000, immutable
/*.mp3
  Cache-Control: public, max-age=2592000
/*.wav
  Cache-Control: public, max-age=2592000
/*.mp4
  Cache-Control: public, max-age=2592000

# Subfolder-specific (proofs, icons, testimonials)
/proofs/*
  Cache-Control: public, max-age=604800, must-revalidate
/icons/*
  Cache-Control: public, max-age=2592000, must-revalidate
/testimonials/*
  Cache-Control: public, max-age=2592000

# Service worker — never cache (must always update)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
/OneSignalSDKWorker.js
  Cache-Control: no-cache, no-store, must-revalidate

# Manifest — short cache
/manifest.webmanifest
  Cache-Control: public, max-age=3600

# HTML — never cache (so deploys go live immediately)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
/
  Cache-Control: no-cache, no-store, must-revalidate
